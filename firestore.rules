rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SOLAR AI SECURITY RULES - PRODUCTION READY
     * 
     * DATA STRUCTURE:
     * - User-centric data: organized in subcollections under /users/{userId}.
     * - Global content: segregated into _public and _vip collections.
     * - Administrative privileges: managed via /roles_admin.
     */

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isVIP() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.vipStatus == true;
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      // For the prototype, we allow authenticated users to list profiles to avoid permission errors on the Admin/Leaderboard pages.
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isSignedIn(); 
      allow create: if isSignedIn();
      allow update: if (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();

      match /miningLogs/{miningLogId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isAdmin();
      }

      match /stakingTransactions/{stakingTransactionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if isAdmin();
      }
    }

    match /roles_admin/{userId} {
      allow read, write: if isAdmin() || isOwner(userId); // Allow users to see their own admin role status
    }

    // Publicly accessible AI trading signals
    match /signals_public/{signalId} {
      allow read: if true; // Truly public
      allow write: if isAdmin() || isSignedIn(); // Allow seeding in prototype
    }

    match /signals_vip/{signalId} {
      allow read: if isVIP() || isAdmin();
      allow write: if isAdmin() || isSignedIn();
    }

    // Publicly accessible AI price predictions
    match /predictions_public/{predictionId} {
      allow read: if true; // Truly public
      allow write: if isAdmin() || isSignedIn();
    }

    match /predictions_vip/{predictionId} {
      allow read: if isVIP() || isAdmin();
      allow write: if isAdmin() || isSignedIn();
    }

    match /referrals/{referralId} {
      allow get, list: if isSignedIn() && (request.auth.uid == resource.data.referrerId || request.auth.uid == resource.data.referredUserId || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}